{
    "name": "ai-tests-automation",
    "version": "1.0.0",
    "private": true,
    "description": "JavaScript Playwright test automation framework",
    "scripts": {
        "test": "playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "report": "playwright show-report",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^9.26.0",
        "@playwright/test": "^1.54.2",
        "dotenv": "^17.4.2",
        "eslint": "^9.26.0",
        "eslint-config-prettier": "^9.1.0",
        "globals": "^15.15.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.1",
        "prettier": "^3.5.3"
    },
    "dependencies": {
        "playwright": "^1.59.1"
    }
}
